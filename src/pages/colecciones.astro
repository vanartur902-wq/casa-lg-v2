---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Colecciones | Casa L&G Premium">
  <main class="bg-[#0b0707] min-h-screen text-white font-sans relative overflow-hidden">
    
    <section class="pt-32 pb-16 px-6 relative z-10">
      <div class="max-w-7xl mx-auto text-center">
        <p class="text-[#C5A059] tracking-[0.8em] text-[10px] uppercase mb-4 animate-fade-in">El Corazón de la Marca</p>
        <h1 class="font-premium text-4xl md:text-7xl text-white tracking-widest uppercase mb-6 animate-slide-up">Colecciones</h1>
        <p class="max-w-2xl mx-auto text-white/40 font-light leading-relaxed text-sm md:text-base animate-fade-in [animation-delay:400ms]">
          Una curaduría sofisticada donde la esencia de Casa L&G se manifiesta en cada detalle, organizada para elevar sus momentos más significativos.
        </p>
        <div class="h-[1px] w-20 bg-[#C5A059]/30 mx-auto mt-10"></div>
      </div>
    </section>

    <section class="pb-32 px-6 max-w-7xl mx-auto relative z-20">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-6 auto-rows-[300px] md:auto-rows-[400px]">
        
        <div onclick="openCollection('floral')" class="md:col-span-8 group relative cursor-pointer overflow-hidden border border-white/5 bg-[#120c0c] transition-all duration-500 hover:border-[#C5A059]/40">
          <img src="https://images.unsplash.com/photo-1526047932273-341f2a7631f9?auto=format&fit=crop&q=80&w=1200" class="absolute inset-0 w-full h-full object-cover opacity-30 group-hover:scale-105 group-hover:opacity-50 transition-all duration-1000" />
          <div class="absolute inset-0 bg-gradient-to-t from-[#0b0707] via-transparent to-transparent"></div>
          <div class="absolute bottom-8 left-8">
            <span class="text-[#C5A059] text-[9px] tracking-[0.4em] uppercase mb-2 block">Diseño de Autor</span>
            <h3 class="font-premium text-3xl text-white tracking-widest uppercase">Atelier Floral</h3>
          </div>
        </div>

        <div onclick="openCollection('cajas')" class="md:col-span-4 group relative cursor-pointer overflow-hidden border border-white/5 bg-[#120c0c] transition-all duration-500 hover:border-[#C5A059]/40">
          <img src="https://images.unsplash.com/photo-1549465220-1a8b9238cd48?auto=format&fit=crop&q=80&w=1200" class="absolute inset-0 w-full h-full object-cover opacity-30 group-hover:scale-105 group-hover:opacity-50 transition-all duration-1000" />
          <div class="absolute inset-0 bg-gradient-to-t from-[#0b0707] via-transparent to-transparent"></div>
          <div class="absolute bottom-8 left-8">
            <span class="text-[#C5A059] text-[9px] tracking-[0.4em] uppercase mb-2 block">Gourmet VIP</span>
            <h3 class="font-premium text-2xl text-white tracking-widest uppercase">Cajas Exclusivas</h3>
          </div>
        </div>

        <div onclick="openCollection('romance')" class="md:col-span-4 group relative cursor-pointer overflow-hidden border border-white/5 bg-[#120c0c] transition-all duration-500 hover:border-[#C5A059]/40">
          <img src="https://images.unsplash.com/photo-1518131359149-63d011205663?auto=format&fit=crop&q=80&w=1200" class="absolute inset-0 w-full h-full object-cover opacity-30 group-hover:scale-105 group-hover:opacity-50 transition-all duration-1000" />
          <div class="absolute inset-0 bg-gradient-to-t from-[#0b0707] via-transparent to-transparent"></div>
          <div class="absolute bottom-8 left-8">
            <span class="text-[#C5A059] text-[9px] tracking-[0.4em] uppercase mb-2 block">Momentos Íntimos</span>
            <h3 class="font-premium text-2xl text-white tracking-widest uppercase">Edición Romance</h3>
          </div>
        </div>

        <div onclick="openCollection('social')" class="md:col-span-4 group relative cursor-pointer overflow-hidden border border-white/5 bg-[#120c0c] transition-all duration-500 hover:border-[#C5A059]/40">
          <img src="https://images.unsplash.com/photo-1539310333207-67c2980495b7?auto=format&fit=crop&q=80&w=1200" class="absolute inset-0 w-full h-full object-cover opacity-30 group-hover:scale-105 group-hover:opacity-50 transition-all duration-1000" />
          <div class="absolute inset-0 bg-gradient-to-t from-[#0b0707] via-transparent to-transparent"></div>
          <div class="absolute bottom-8 left-8">
            <span class="text-[#C5A059] text-[9px] tracking-[0.4em] uppercase mb-2 block">Experiencias</span>
            <h3 class="font-premium text-2xl text-white tracking-widest uppercase">Colección Social</h3>
          </div>
        </div>

        <div onclick="openCollection('prestige')" class="md:col-span-4 group relative cursor-pointer overflow-hidden border border-white/5 bg-[#120c0c] transition-all duration-500 hover:border-[#C5A059]/40">
          <img src="https://images.unsplash.com/photo-1513519245088-0e12902e5a38?auto=format&fit=crop&q=80&w=1200" class="absolute inset-0 w-full h-full object-cover opacity-20 group-hover:scale-105 group-hover:opacity-40 transition-all duration-1000" />
          <div class="absolute inset-0 bg-gradient-to-t from-[#0b0707] via-[#C5A059]/10 to-transparent"></div>
          <div class="absolute bottom-8 left-8 text-left">
            <span class="text-[#C5A059] text-[9px] tracking-[0.6em] uppercase mb-2 block">High-End Luxury</span>
            <h3 class="font-premium text-2xl text-white tracking-widest uppercase">Colección Prestige</h3>
          </div>
        </div>

      </div>
    </section>

    <div id="collection-view" class="hidden fixed inset-0 z-[150] bg-[#0b0707] overflow-y-auto animate-fade-in transition-all duration-500">
      
      <button onclick="closeCollection()" class="fixed top-28 right-2 md:top-24 md:right-4 z-[200] text-[#C5A059] hover:text-white bg-black/80 hover:bg-black w-10 h-10 md:w-11 md:h-11 flex items-center justify-center rounded-full border border-[#C5A059]/30 transition-all duration-300 group cursor-pointer" aria-label="Cerrar">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.2" stroke="currentColor" class="w-5 h-5 md:w-5 md:h-5 group-hover:rotate-90 transition-transform duration-300">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>

      <div class="max-w-6xl mx-auto px-6 pt-32 md:pt-16 pb-20 relative">
        <div id="collection-content"></div>
      </div>
    </div>

  </main>
</Layout>

<script is:inline>
  const catalog = {
    floral: {
      title: "Atelier Floral",
      subtitle: "Artesanía Botánica",
      content: `
        <p class="text-white/50 font-light mb-12 max-w-2xl leading-relaxed">Arreglos florales delicados, modernos y elegantes. Nuestra división Atelier fusiona el minimalismo con la frescura natural de flores premium seleccionadas bajo estricta calidad.</p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div class="space-y-4">
            <img src="https://images.unsplash.com/photo-1527061011665-3652c757a4d4?auto=format&fit=crop&q=80&w=800" class="w-full h-[400px] object-cover rounded-sm border border-white/10" />
            <h4 class="font-premium text-xl uppercase text-[#C5A059]">Orquídea Real Blanca</h4>
            <p class="text-white/40 text-xs">Presentada en base de mármol pulido o cerámica minimalista.</p>
          </div>
          <div class="space-y-4">
            <img src="https://images.unsplash.com/photo-1561181286-d3fea73e413f?auto=format&fit=crop&q=80&w=800" class="w-full h-[400px] object-cover rounded-sm border border-white/10" />
            <h4 class="font-premium text-xl uppercase text-[#C5A059]">Arreglo Estructural "L&G"</h4>
            <p class="text-white/40 text-xs">Diseño vertical con rosas blancas y follaje de eucalipto premium.</p>
          </div>
        </div>
      `
    },
    cajas: {
      title: "Cajas Exclusivas",
      subtitle: "Gifts Corporativos & VIP",
      content: `
        <p class="text-white/50 font-light mb-12 max-w-2xl leading-relaxed">Detalles premium con vinos seleccionados, chocolates de autor, frutos secos y selecciones gourmet presentadas en nuestras icónicas cajas rígidas con acabado seda.</p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="bg-white/[0.02] border border-white/5 p-4">
            <img src="https://images.unsplash.com/photo-1513201099705-a9746e1e201f?auto=format&fit=crop&q=80&w=600" class="w-full h-64 object-cover mb-4" />
            <h5 class="font-premium text-sm uppercase">Cofre Wine & Dark Chocolate</h5>
          </div>
          <div class="bg-white/[0.02] border border-white/5 p-4">
            <img src="https://images.unsplash.com/photo-1622327532398-e70a649875f6?auto=format&fit=crop&q=80&w=600" class="w-full h-64 object-cover mb-4" />
            <h5 class="font-premium text-sm uppercase">Box Gourmet Selección L&G</h5>
          </div>
          <div class="bg-white/[0.02] border border-white/5 p-4">
            <img src="https://images.unsplash.com/photo-1549465220-1a8b9238cd48?auto=format&fit=crop&q=80&w=600" class="w-full h-64 object-cover mb-4" />
            <h5 class="font-premium text-sm uppercase">Luxury Gin & Botanical Box</h5>
          </div>
        </div>
      `
    },
    romance: {
      title: "Edición Romance",
      subtitle: "Legado de Amor",
      content: `
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div class="order-2 lg:order-1">
            <img src="https://images.unsplash.com/photo-1518131359149-63d011205663?auto=format&fit=crop&q=80&w=800" class="w-full h-[600px] object-cover" />
          </div>
          <div class="space-y-8 order-1 lg:order-2">
            <h3 class="font-premium text-3xl text-white uppercase tracking-widest">Momentos Eternos</h3>
            <p class="text-white/50 leading-relaxed font-light">Detalles pensados para parejas y celebraciones de aniversario. Incluye nuestra línea de velas aromáticas, champagne brut y cristalería grabada.</p>
            <ul class="space-y-4 text-xs uppercase tracking-[0.2em] text-[#C5A059]">
              <li><i class="fa-solid fa-check mr-2 opacity-50"></i> Champagne Flutes Engraved</li>
              <li><i class="fa-solid fa-check mr-2 opacity-50"></i> Luxury Red Rose Selection</li>
              <li><i class="fa-solid fa-check mr-2 opacity-50"></i> Personalized Anniversary Cards</li>
            </ul>
          </div>
        </div>
      `
    },
    social: {
      title: "Colección Social",
      subtitle: "El Arte de Compartir",
      content: `
        <p class="text-white/50 font-light mb-12 max-w-2xl">Tablas gourmet, brunch y celebraciones diseñadas para ser el centro de atención de sus reuniones sociales.</p>
        <div class="columns-1 md:columns-2 gap-6 space-y-6">
          <img src="https://images.unsplash.com/photo-1539310333207-67c2980495b7?auto=format&fit=crop&q=80&w=600" class="w-full rounded-sm border border-white/5" />
          <img src="https://images.unsplash.com/photo-1510812431401-41d2bd2722f3?auto=format&fit=crop&q=80&w=600" class="w-full rounded-sm border border-white/5" />
          <div class="p-8 bg-white/[0.02] border border-[#C5A059]/20 text-center">
            <h4 class="font-premium text-lg mb-4">Tablas Gourmet a Medida</h4>
            <p class="text-white/40 text-xs uppercase tracking-widest">Desde 4 hasta 20 personas.</p>
          </div>
        </div>
      `
    },
    prestige: {
      title: "Colección Prestige",
      subtitle: "El Límite de la Exclusividad",
      content: `
        <div class="flex flex-col items-center text-center max-w-3xl mx-auto py-12">
          <div class="w-24 h-24 border border-[#C5A059]/20 flex items-center justify-center rounded-full mb-10 text-[#C5A059]">
            <i class="fa-solid fa-crown text-3xl"></i>
          </div>
          <h3 class="font-premium text-4xl text-white mb-6 uppercase tracking-wider">Línea de Alta Orfebrería</h3>
          <p class="text-white/40 font-light leading-relaxed mb-10">
            Los detalles más exclusivos de la marca. Incluye nuestras piezas preservadas en oro de 24K, ediciones numeradas y cofres de cuero genuino para clientes de gusto impecable.
          </p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8 w-full mt-10">
            <div class="aspect-square bg-white/[0.02] border border-white/10 flex items-center justify-center p-12">
              <img src="https://images.unsplash.com/photo-1513519245088-0e12902e5a38?auto=format&fit=crop&q=80&w=600" class="w-full h-full object-contain opacity-60" />
            </div>
            <div class="flex flex-col justify-center text-left space-y-6">
              <span class="text-[#C5A059] text-[9px] tracking-widest uppercase">Edición Oro 24K</span>
              <h4 class="font-premium text-2xl uppercase">Rosa Preservada Prestige</h4>
              <p class="text-white/30 text-xs">Un símbolo eterno de distinción presentado en cápsula de cristal de alta claridad.</p>
              <a href="https://wa.me/51953435738" class="inline-block py-4 px-8 border border-[#C5A059] text-[#C5A059] text-[9px] font-bold uppercase tracking-widest hover:bg-[#C5A059] hover:text-black transition-all">Solicitar Dossier Prestige</a>
            </div>
          </div>
        </div>
      `
    }
  };

  function openCollection(key) {
    const data = catalog[key];
    const view = document.getElementById('collection-view');
    const content = document.getElementById('collection-content');
    
    content.innerHTML = `
      <div class="mb-16 animate-slide-up pr-12">
        <span class="text-[#C5A059] tracking-[0.6em] uppercase text-[10px] mb-2 block font-light">${data.subtitle}</span>
        <h2 class="font-premium text-4xl md:text-6xl text-white uppercase tracking-widest leading-tight">${data.title}</h2>
        <div class="h-[1px] w-16 bg-[#C5A059]/40 mt-8"></div>
      </div>
      <div class="animate-fade-in [animation-delay:400ms]">
        ${data.content}
      </div>
    `;
    
    view.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeCollection() {
    const view = document.getElementById('collection-view');
    view.classList.add('hidden');
    document.body.style.overflow = 'auto';
  }
</script>

<style>
  .font-premium { font-family: 'Cinzel', serif; }
  
  @keyframes fade-in {
    from { opacity: 0; filter: blur(10px); }
    to { opacity: 1; filter: blur(0); }
  }
  @keyframes slide-up {
    from { opacity: 0; transform: translateY(40px); }
    to { opacity: 1; transform: translateY(0); }
  }
  
  .animate-fade-in { animation: fade-in 1.2s ease-out forwards; }
  .animate-slide-up { animation: slide-up 1s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
</style>