---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Colecciones | Casa L&G Premium">
  <main class="bg-[#0b0707] min-h-screen text-white font-sans relative overflow-hidden">
    
    <section class="pt-32 pb-16 px-6 relative z-10">
      <div class="max-w-7xl mx-auto text-center">
        <p class="text-[#C5A059] tracking-[0.8em] text-[10px] uppercase mb-4 animate-fade-in">El Corazón de la Marca</p>
        <h1 class="font-premium text-4xl md:text-7xl text-white tracking-widest uppercase mb-6 animate-slide-up">Colecciones</h1>
        <p class="max-w-2xl mx-auto text-white/40 font-light leading-relaxed text-sm md:text-base animate-fade-in [animation-delay:400ms]">
          Una curaduría sofisticada donde la esencia de Casa L&G se manifiesta en cada detalle, organizada para elevar sus momentos más significativos.
        </p>
        <div class="h-[1px] w-20 bg-[#C5A059]/30 mx-auto mt-10"></div>
      </div>
    </section>

    <section class="pb-32 px-6 max-w-7xl mx-auto relative z-20">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-6 auto-rows-[300px] md:auto-rows-[400px]">
        
        <div onclick="openCollection('floral')" class="md:col-span-8 group relative cursor-pointer overflow-hidden border border-white/5 bg-[#120c0c] transition-all duration-500 hover:border-[#C5A059]/40">
          <img src="https://images.unsplash.com/photo-1526047932273-341f2a7631f9?auto=format&fit=crop&q=80&w=1200" class="absolute inset-0 w-full h-full object-cover opacity-30 group-hover:scale-105 group-hover:opacity-50 transition-all duration-1000" />
          <div class="absolute inset-0 bg-gradient-to-t from-[#0b0707] via-transparent to-transparent"></div>
          <div class="absolute bottom-8 left-8">
            <span class="text-[#C5A059] text-[9px] tracking-[0.4em] uppercase mb-2 block">Diseño de Autor</span>
            <h3 class="font-premium text-3xl text-white tracking-widest uppercase">Atelier Floral</h3>
          </div>
        </div>

        <div onclick="openCollection('cajas')" class="md:col-span-4 group relative cursor-pointer overflow-hidden border border-white/5 bg-[#120c0c] transition-all duration-500 hover:border-[#C5A059]/40">
          <img src="https://images.unsplash.com/photo-1549465220-1a8b9238cd48?auto=format&fit=crop&q=80&w=1200" class="absolute inset-0 w-full h-full object-cover opacity-30 group-hover:scale-105 group-hover:opacity-50 transition-all duration-1000" />
          <div class="absolute inset-0 bg-gradient-to-t from-[#0b0707] via-transparent to-transparent"></div>
          <div class="absolute bottom-8 left-8">
            <span class="text-[#C5A059] text-[9px] tracking-[0.4em] uppercase mb-2 block">Gourmet VIP</span>
            <h3 class="font-premium text-2xl text-white tracking-widest uppercase">Cajas Exclusivas</h3>
          </div>
        </div>

        <div onclick="openCollection('romance')" class="md:col-span-4 group relative cursor-pointer overflow-hidden border border-white/5 bg-[#120c0c] transition-all duration-500 hover:border-[#C5A059]/40">
          <img src="https://images.unsplash.com/photo-1518131359149-63d011205663?auto=format&fit=crop&q=80&w=1200" class="absolute inset-0 w-full h-full object-cover opacity-30 group-hover:scale-105 group-hover:opacity-50 transition-all duration-1000" />
          <div class="absolute inset-0 bg-gradient-to-t from-[#0b0707] via-transparent to-transparent"></div>
          <div class="absolute bottom-8 left-8">
            <span class="text-[#C5A059] text-[9px] tracking-[0.4em] uppercase mb-2 block">Momentos Íntimos</span>
            <h3 class="font-premium text-2xl text-white tracking-widest uppercase">Edición Romance</h3>
          </div>
        </div>

        <div onclick="openCollection('social')" class="md:col-span-4 group relative cursor-pointer overflow-hidden border border-white/5 bg-[#120c0c] transition-all duration-500 hover:border-[#C5A059]/40">
          <img src="https://images.unsplash.com/photo-1539310333207-67c2980495b7?auto=format&fit=crop&q=80&w=1200" class="absolute inset-0 w-full h-full object-cover opacity-30 group-hover:scale-105 group-hover:opacity-50 transition-all duration-1000" />
          <div class="absolute inset-0 bg-gradient-to-t from-[#0b0707] via-transparent to-transparent"></div>
          <div class="absolute bottom-8 left-8">
            <span class="text-[#C5A059] text-[9px] tracking-[0.4em] uppercase mb-2 block">Experiencias</span>
            <h3 class="font-premium text-2xl text-white tracking-widest uppercase">Colección Social</h3>
          </div>
        </div>

        <div onclick="openCollection('prestige')" class="md:col-span-4 group relative cursor-pointer overflow-hidden border border-white/5 bg-[#120c0c] transition-all duration-500 hover:border-[#C5A059]/40">
          <img src="https://images.unsplash.com/photo-1513519245088-0e12902e5a38?auto=format&fit=crop&q=80&w=1200" class="absolute inset-0 w-full h-full object-cover opacity-20 group-hover:scale-105 group-hover:opacity-40 transition-all duration-1000" />
          <div class="absolute inset-0 bg-gradient-to-t from-[#0b0707] via-[#C5A059]/10 to-transparent"></div>
          <div class="absolute bottom-8 left-8 text-left">
            <span class="text-[#C5A059] text-[9px] tracking-[0.6em] uppercase mb-2 block">High-End Luxury</span>
            <h3 class="font-premium text-2xl text-white tracking-widest uppercase">Colección Prestige</h3>
          </div>
        </div>

      </div>
    </section>

    <div id="collection-view" class="hidden fixed bottom-0 left-0 right-0 top-[76px] md:top-[90px] z-[140] bg-[#0b0707] overflow-y-auto border-t border-white/5 animate-fade-in">
      
      <div class="sticky top-0 right-0 w-full flex justify-end p-4 z-[160] pointer-events-none">
        <button onclick="closeCollection()" class="pointer-events-auto bg-black/90 hover:bg-black text-[#C5A059] hover:text-white w-10 h-10 flex items-center justify-center rounded-full border border-[#C5A059]/30 transition-all duration-300 group cursor-pointer shadow-lg" aria-label="Cerrar">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5 group-hover:rotate-90 transition-transform duration-300">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <div class="max-w-7xl mx-auto px-6 pb-24 -mt-8 relative">
        <div id="collection-content"></div>
      </div>
    </div>

  </main>
</MainLayout>

<script is:inline>
  // Catálogo optimizado con los mismos estilos visuales que tus Productos Destacados
  const catalog = {
    floral: {
      title: "Atelier Floral",
      subtitle: "Artesanía Botánica",
      desc: "Arreglos florales delicados, modernos y elegantes. Nuestra división Atelier fusiona el minimalismo con la frescura natural de flores premium seleccionadas bajo estricta calidad.",
      items: [
        {
          tag: "DISEÑO DE AUTOR",
          name: "Orquídea Real Premium",
          price: "S/180.00",
          img: "https://images.unsplash.com/photo-1527061011665-3652c757a4d4?auto=format&fit=crop&q=80&w=600"
        },
        {
          tag: "ESTRUCTURAL PREMIUM",
          name: "Arreglo Silvestre L&G",
          price: "S/210.00",
          img: "https://images.unsplash.com/photo-1561181286-d3fea73e413f?auto=format&fit=crop&q=80&w=600"
        },
        {
          tag: "EDICIÓN LIMITADA",
          name: "Bouquet Minimalista Oro",
          price: "S/165.00",
          img: "https://images.unsplash.com/photo-1596436889106-be35e843f974?auto=format&fit=crop&q=80&w=600"
        }
      ]
    },
    cajas: {
      title: "Cajas Exclusivas",
      subtitle: "Gifts Corporativos & VIP",
      desc: "Detalles premium con vinos seleccionados, chocolates de autor, frutos secos y selecciones gourmet presentadas en nuestras icónicas cajas rígidas con acabado seda.",
      items: [
        {
          tag: "DETALLE PREMIUM",
          name: "Cofre Wine & Dark Chocolate",
          price: "S/150.00",
          img: "https://images.unsplash.com/photo-1513201099705-a9746e1e201f?auto=format&fit=crop&q=80&w=600"
        },
        {
          tag: "GIFTS VIP",
          name: "Box Gourmet Selección L&G",
          price: "S/125.00",
          img: "https://images.unsplash.com/photo-1622327532398-e70a649875f6?auto=format&fit=crop&q=80&w=600"
        },
        {
          tag: "REGALOS LUXURY",
          name: "Bunny Box Premium",
          price: "S/310.00",
          img: "https://images.unsplash.com/photo-1549465220-1a8b9238cd48?auto=format&fit=crop&q=80&w=600"
        }
      ]
    },
    romance: {
      title: "Edición Romance",
      subtitle: "Legado de Amor",
      desc: "Detalles pensados minuciosamente para parejas y momentos especiales. Marque la diferencia en aniversarios y fechas memorables con sofisticación.",
      items: [
        {
          tag: "MOMENTOS ÍNTIMOS",
          name: "Cofre Romántico Eterno",
          price: "S/240.00",
          img: "https://images.unsplash.com/photo-1518131359149-63d011205663?auto=format&fit=crop&q=80&w=600"
        },
        {
          tag: "EDICIÓN PASIÓN",
          name: "Arreglo Velvet & Champagne",
          price: "S/350.00",
          img: "https://images.unsplash.com/photo-1529636798458-92182e662485?auto=format&fit=crop&q=80&w=600"
        }
      ]
    },
    social: {
      title: "Colección Social",
      subtitle: "El Arte de Compartir",
      desc: "Experiencias grupales, tablas gourmet premium, alternativas de brunch sofisticados y complementos perfectos para celebraciones de alto nivel.",
      items: [
        {
          tag: "EXPERIENCIAS",
          name: "Tabla Gourmet Compartir",
          price: "S/195.00",
          img: "https://images.unsplash.com/photo-1539310333207-67c2980495b7?auto=format&fit=crop&q=80&w=600"
        },
        {
          tag: "BRUNCH VIP",
          name: "Brunch Box L&G Imperial",
          price: "S/160.00",
          img: "https://images.unsplash.com/photo-1510812431401-41d2bd2722f3?auto=format&fit=crop&q=80&w=600"
        }
      ]
    },
    prestige: {
      title: "Colección Prestige",
      subtitle: "High-End Luxury",
      desc: "Los detalles más exclusivos y de alta gama de la marca. Piezas premium diseñadas para impresionar a los gustos más exigentes.",
      items: [
        {
          tag: "PRESTIGE ORIGINAL",
          name: "Cofre de Cuero & Cristalería",
          price: "S/450.00",
          img: "https://images.unsplash.com/photo-1513519245088-0e12902e5a38?auto=format&fit=crop&q=80&w=600"
        }
      ]
    }
  };

  function openCollection(key) {
    const data = catalog[key];
    const view = document.getElementById('collection-view');
    const content = document.getElementById('collection-content');
    
    // Generación dinámica renderizando exactamente las tarjetas que subiste en tus fotos
    let itemsHTML = '';
    data.items.forEach(item => {
      itemsHTML += `
        <div class="bg-[#120c0c]/60 border border-white/5 p-5 rounded-2xl flex flex-col justify-between transition-all duration-300 hover:border-[#C5A059]/30 group">
          <div>
            <div class="overflow-hidden rounded-xl mb-5 aspect-square bg-[#0b0707] border border-white/5">
              <img src="${item.img}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" alt="${item.name}" />
            </div>
            <span class="text-[#C5A059] text-[9px] tracking-widest uppercase font-semibold block mb-1">${item.tag}</span>
            <h4 class="font-sans text-xl font-medium text-white tracking-wide mb-2">${item.name}</h4>
          </div>
          <p class="text-white/60 font-mono text-sm mt-2">${item.price}</p>
        </div>
      `;
    });

    content.innerHTML = `
      <div class="mb-10 text-left pt-6">
        <span class="text-[#C5A059] tracking-[0.5em] uppercase text-[10px] mb-2 block font-light">${data.subtitle}</span>
        <h2 class="font-premium text-3xl md:text-5xl text-white uppercase tracking-widest">${data.title}</h2>
        <div class="h-[1px] w-12 bg-[#C5A059]/40 mt-4 mb-6"></div>
        <p class="text-white/40 font-light text-sm md:text-base max-w-3xl leading-relaxed">${data.desc}</p>
      </div>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 animate-fade-in">
        ${itemsHTML}
      </div>
    `;
    
    view.classList.remove('hidden');
    // Mantenemos scroll en el body pero la vista se maneja encima de forma nativa
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function closeCollection() {
    const view = document.getElementById('collection-view');
    view.classList.add('hidden');
  }
</script>

<style>
  .font-premium { font-family: 'Cinzel', serif; }
  
  @keyframes fade-in {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes slide-up {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  
  .animate-fade-in { animation: fade-in 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
  .animate-slide-up { animation: slide-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
</style>