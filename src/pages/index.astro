---
import MainLayout from '../layouts/MainLayout.astro';
import Hero from '../components/Hero.astro';
import ProductCard from '../components/ProductCard.astro';
---
<MainLayout title="Exclusividad | Casa L&G">
  <Hero />
  
  <section class="py-32 px-6">
    <div class="max-w-7xl mx-auto">
      <div class="flex flex-col md:flex-row justify-between items-end mb-20 gap-8">
        <div>
          <h2 class="font-display text-4xl md:text-6xl mb-4">Nuestra <span class="text-luxury-gold">Curaduría</span></h2>
          <p class="text-white/40 tracking-widest text-[10px] uppercase">Piezas seleccionadas para el gusto más exigente</p>
        </div>
        <a href="/catalogo" class="text-luxury-gold text-[10px] tracking-widest uppercase border-b border-luxury-gold pb-1 hover:text-white hover:border-white transition-all">Ver Todo</a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
        <ProductCard 
          title="Caja Sorpresa" 
          price="S/150.00" 
          image="https://i.pinimg.com/1200x/92/1b/8b/921b8b6b062006c00cb165d2c35844de.jpg" 
          category="Detalle Día Del Padre"
        />
        <ProductCard 
          title="Caja Oro" 
          price="S/125.00" 
          image="https://i.pinimg.com/1200x/46/e7/51/46e751b112f4ebe5c69b0574000c2718.jpg" 
          category="Gifts VIP"
        />
        <ProductCard 
          title="Bunny Box Premium" 
          price="S/310.00" 
          image="https://i.pinimg.com/1200x/11/4a/c7/114ac7e62469500fd0398d1abf25fa58.jpg" 
          category="Regalos Bunny Box"
        />
      </div>
    </div>
  </section>
</MainLayout>