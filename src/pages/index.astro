---
import MainLayout from '../layouts/MainLayout.astro';
import Hero from '../components/Hero.astro';
---

<MainLayout title="Inicio | Casa L&G">
  <Hero />
  
  <main class="bg-[#0b0707] text-white overflow-hidden font-sans relative">
    
    <div class="flex flex-col items-center justify-center -mt-20 mb-16 relative z-30 animate-bounce-soft">
      <span class="text-[9px] uppercase tracking-[0.4em] text-[#C5A059] mb-3 font-light">Explorar Esencia</span>
      <div class="w-[1px] h-10 bg-gradient-to-b from-[#C5A059] to-transparent"></div>
    </div>

    <section class="py-20 px-6 max-w-7xl mx-auto relative z-20">
      <div class="text-center max-w-3xl mx-auto mb-20">
        <h2 class="font-premium text-3xl md:text-5xl mb-6 tracking-wide uppercase">La esencia de Casa L&G</h2>
        <p class="text-white/50 text-sm md:text-base leading-relaxed font-light">
          Una presentación elegante de la marca donde los clientes descubren detalles exclusivos, colecciones especiales y experiences memorables para cada ocasión.
        </p>
        <div class="h-[1px] w-12 bg-[#C5A059]/30 mx-auto mt-8"></div>
      </div>

      <div id="main-grid" class="grid grid-cols-1 md:grid-cols-3 gap-8 transition-all duration-700">
        
        <div onclick="openSection('productos')" class="group relative h-[450px] md:h-[550px] cursor-pointer overflow-hidden border border-white/5 transition-all duration-500 hover:border-[#C5A059]/40 bg-[#120c0c]">
          <img src="https://i.pinimg.com/1200x/11/4a/c7/114ac7e62469500fd0398d1abf25fa58.jpg" class="absolute inset-0 w-full h-full object-cover opacity-30 group-hover:scale-105 group-hover:opacity-50 transition-all duration-1000" alt="Productos Destacados" />
          <div class="absolute inset-0 bg-gradient-to-t from-[#0b0707] via-transparent to-transparent"></div>
          <div class="absolute bottom-10 left-10 text-left">
            <span class="text-[#C5A059] text-[9px] tracking-[0.4em] uppercase mb-2 block">Curaduría</span>
            <h3 class="font-premium text-2xl text-white tracking-widest uppercase">Productos<br/>Destacados</h3>
          </div>
        </div>

        <div onclick="openSection('temporadas')" class="group relative h-[450px] md:h-[550px] cursor-pointer overflow-hidden border border-white/5 transition-all duration-500 hover:border-[#C5A059]/40 bg-[#120c0c]">
          <img src="https://i.pinimg.com/1200x/46/e7/51/46e751b112f4ebe5c69b0574000c2718.jpg" class="absolute inset-0 w-full h-full object-cover opacity-30 group-hover:scale-105 group-hover:opacity-50 transition-all duration-1000" alt="Temporadas Especiales" />
          <div class="absolute inset-0 bg-gradient-to-t from-[#0b0707] via-transparent to-transparent"></div>
          <div class="absolute bottom-10 left-10 text-left">
            <span class="text-[#C5A059] text-[9px] tracking-[0.4em] uppercase mb-2 block">Ediciones</span>
            <h3 class="font-premium text-2xl text-white tracking-widest uppercase">Temporadas<br/>Especiales</h3>
          </div>
        </div>

        <div onclick="openSection('colecciones')" class="group relative h-[450px] md:h-[550px] cursor-pointer overflow-hidden border border-white/5 transition-all duration-500 hover:border-[#C5A059]/40 bg-[#120c0c]">
          <img src="https://i.pinimg.com/1200x/92/1b/8b/921b8b6b062006c00cb165d2c35844de.jpg" class="absolute inset-0 w-full h-full object-cover opacity-30 group-hover:scale-105 group-hover:opacity-50 transition-all duration-1000" alt="Nuevas Colecciones" />
          <div class="absolute inset-0 bg-gradient-to-t from-[#0b0707] via-transparent to-transparent"></div>
          <div class="absolute bottom-10 left-10 text-left">
            <span class="text-[#C5A059] text-[9px] tracking-[0.4em] uppercase mb-2 block">Lanzamientos</span>
            <h3 class="font-premium text-2xl text-white tracking-widest uppercase">Nuevas<br/>Colecciones</h3>
          </div>
        </div>

      </div>

      <div id="detail-view" class="hidden fixed inset-0 z-[150] bg-[#0b0707] p-6 md:p-20 overflow-y-auto animate-fade-in transition-all duration-500">
        
        <button onclick="closeSection()" class="fixed top-5 right-5 md:top-10 md:right-10 z-[999] text-[#C5A059] hover:text-white bg-black/80 hover:bg-black w-10 h-10 md:w-12 md:h-12 flex items-center justify-center rounded-full border border-[#C5A059]/40 shadow-2xl transition-all duration-300 group cursor-pointer" aria-label="Cerrar">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5 md:w-6 md:h-6 group-hover:rotate-90 transition-transform duration-300">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>

        <div id="detail-content" class="max-w-6xl mx-auto pt-28 md:pt-12 pb-12">
          </div>
      </div>
    </section>
  </main>
</MainLayout>

<script is:inline>
  // CONTENIDO DINÁMICO CON LA TEMÁTICA ESTÁNDAR DE ORO
  const sections = {
    productos: {
      title: "Productos Destacados",
      subtitle: "Piezas de Alta Gama",
      content: `
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-10 mt-12">
          <div class="group bg-white/[0.01] border border-white/5 p-6 rounded-2xl transition-all duration-300 hover:border-[#C5A059]/20">
            <div class="overflow-hidden mb-6 aspect-square rounded-lg border border-white/5"><img src="https://i.pinimg.com/1200x/92/1b/8b/921b8b6b062006c00cb165d2c35844de.jpg" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" alt="Caja Sorpresa" /></div>
            <span class="text-[#C5A059] text-[9px] tracking-widest uppercase mb-1 block">Detalle Día Del Padre</span>
            <h4 class="font-premium text-xl text-white mb-2">Caja Sorpresa</h4>
            <span class="text-white/60 font-medium">S/150.00</span>
          </div>
          <div class="group bg-white/[0.01] border border-white/5 p-6 rounded-2xl transition-all duration-300 hover:border-[#C5A059]/20">
            <div class="overflow-hidden mb-6 aspect-square rounded-lg border border-white/5"><img src="https://i.pinimg.com/1200x/46/e7/51/46e751b112f4ebe5c69b0574000c2718.jpg" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" alt="Caja Oro" /></div>
            <span class="text-[#C5A059] text-[9px] tracking-widest uppercase mb-1 block">Gifts VIP</span>
            <h4 class="font-premium text-xl text-white mb-2">Caja Oro</h4>
            <span class="text-white/60 font-medium">S/125.00</span>
          </div>
          <div class="group bg-white/[0.01] border border-white/5 p-6 rounded-2xl transition-all duration-300 hover:border-[#C5A059]/20">
            <div class="overflow-hidden mb-6 aspect-square rounded-lg border border-white/5"><img src="https://i.pinimg.com/1200x/11/4a/c7/114ac7e62469500fd0398d1abf25fa58.jpg" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" alt="Bunny Box Premium" /></div>
            <span class="text-[#C5A059] text-[9px] tracking-widest uppercase mb-1 block">Regalos Bunny Box</span>
            <h4 class="font-premium text-xl text-white mb-2">Bunny Box Premium</h4>
            <span class="text-white/60 font-medium">S/310.00</span>
          </div>
        </div>
      `
    },
    temporadas: {
      title: "Temporadas Especiales",
      subtitle: "Celebraciones Exclusivas",
      content: `
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center mt-12">
          <div class="space-y-6">
            <span class="text-[#C5A059] text-[10px] tracking-[0.3em] uppercase block">Línea Temporal Autor</span>
            <h3 class="font-premium text-3xl md:text-5xl text-white uppercase tracking-wide">Momentos Eternos</h3>
            <p class="text-white/50 font-light leading-relaxed">Diseñamos colecciones efímeras y adaptadas a las festividades más importantes del año. Piezas por tiempo limitado con empaques temáticos estructurales únicos.</p>
            <div class="h-[1px] w-20 bg-[#C5A059]/40 py-2"></div>
            <p class="text-[#C5A059] text-xs uppercase tracking-widest">Próxima Edición: San Valentín & Eventos Corporativos</p>
          </div>
          <div class="h-[400px] border border-white/10 overflow-hidden rounded-lg">
            <img src="https://i.pinimg.com/1200x/46/e7/51/46e751b112f4ebe5c69b0574000c2718.jpg" class="w-full h-full object-cover" alt="Temporadas" />
          </div>
        </div>
      `
    },
    colecciones: {
      title: "Nuevas Colecciones",
      subtitle: "Lanzamientos de Reserva",
      content: `
        <div class="flex flex-col items-center text-center py-12 max-w-2xl mx-auto">
          <div class="w-20 h-20 border border-[#C5A059]/20 flex items-center justify-center rounded-full mb-8 text-[#C5A059] bg-white/[0.01]">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
            </svg>
          </div>
          <h3 class="font-premium text-4xl text-white mb-6 uppercase tracking-wider">Línea Prestige Limitada</h3>
          <p class="text-white/40 font-light leading-relaxed mb-8">
            Acceda a nuestros últimos diseños estructurales en cajas y cofres de cuero y acabados metálicos de precisión láser. Disponibles únicamente bajo pedido anticipado y reserva selecta.
          </p>
          <a href="https://wa.me/51953435738" target="_blank" class="px-10 py-4 bg-transparent border border-[#C5A059] text-[#C5A059] uppercase tracking-widest text-[10px] font-bold hover:bg-[#C5A059] hover:text-black transition-all">Consultar Disponibilidad</a>
        </div>
      `
    }
  };

  function openSection(key) {
    const data = sections[key];
    const detailView = document.getElementById('detail-view');
    const content = document.getElementById('detail-content');
    
    content.innerHTML = `
      <div class="mb-12 animate-slide-up">
        <span class="text-[#C5A059] tracking-[0.5em] uppercase text-[10px] mb-2 block">${data.subtitle}</span>
        <h1 class="font-premium text-4xl md:text-6xl text-white uppercase tracking-widest leading-tight">${data.title}</h1>
        <div class="h-[1px] w-16 bg-[#C5A059]/30 mt-6"></div>
      </div>
      <div class="animate-fade-in [animation-delay:300ms]">
        ${data.content}
      </div>
    `;
    
    detailView.classList.remove('hidden');
    document.body.style.overflow = 'hidden'; 
  }

  function closeSection() {
    const detailView = document.getElementById('detail-view');
    detailView.classList.add('hidden');
    document.body.style.overflow = 'auto'; 
  }
</script>

<style>
  .font-premium { font-family: 'Cinzel', serif; }
  
  @keyframes bounce-soft {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }
  
  @keyframes fade-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  @keyframes slide-up {
    from { opacity: 0; transform: translateY(40px); }
    to { opacity: 1; transform: translateY(0); }
  }
  
  .animate-bounce-soft { animation: bounce-soft 3s ease-in-out infinite; }
  .animate-fade-in { animation: fade-in 0.8s ease-out forwards; }
  .animate-slide-up { animation: slide-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
</style>