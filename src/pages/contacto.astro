---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Atención Exclusiva">
  <section class="h-screen flex items-center justify-center bg-brand-dark px-6">
    <div class="max-w-2xl text-center border border-brand-gold/20 p-16 backdrop-blur-md relative overflow-hidden">
      <div class="absolute -top-10 -left-10 w-32 h-32 bg-brand-gold/5 rounded-full blur-3xl"></div>
      
      <h2 class="text-brand-cream font-premium text-4xl mb-6 tracking-widest uppercase">Haz tu Pedido</h2>
      <p class="text-brand-rose font-body mb-10 tracking-[0.1em] text-sm leading-loose">
        Cada detalle es una obra de arte. Contáctanos para personalizar tu experiencia y asegurar la perfección en tu entrega.
      </p>
      
      <a href="https://wa.me/+51953435738" target="_blank" class="inline-block bg-brand-gold text-brand-dark px-12 py-5 font-bold uppercase text-[10px] tracking-[0.4em] hover:bg-brand-cream hover:tracking-[0.5em] transition-all duration-700 shadow-2xl">
        WhatsApp VIP Directo
      </a>
    </div>
  </section>
</MainLayout>