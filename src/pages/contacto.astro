---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Contacto VIP | Casa L&G">
  <main class="bg-[#0b0707] text-white min-h-screen relative flex items-center justify-center py-24 px-6 overflow-hidden">
    
    <div class="absolute inset-0 z-0">
      <div class="absolute top-[-20%] right-[-10%] w-[600px] h-[600px] bg-[#C5A059] opacity-[0.02] blur-[150px] rounded-full"></div>
      <div class="absolute bottom-[-20%] left-[-10%] w-[600px] h-[600px] bg-white opacity-[0.01] blur-[150px] rounded-full"></div>
    </div>

    <div class="relative z-10 w-full max-w-6xl mx-auto">
      
      <div class="text-center mb-20 animate-fade-in">
        <p class="font-sans text-[#C5A059] tracking-[0.8em] text-[10px] md:text-[11px] uppercase mb-4">
          Atención Exclusiva
        </p>
        <h1 class="font-premium text-4xl md:text-7xl text-white tracking-tighter uppercase">
          Canales de <span class="italic text-transparent bg-clip-text bg-gradient-to-r from-white via-[#C5A059] to-white">Contacto</span>
        </h1>
        <div class="h-[1px] w-16 bg-[#C5A059]/40 mx-auto mt-6"></div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-start">
        
        <div class="lg:col-span-5 space-y-10 font-sans animate-slide-up">
          <div>
            <h2 class="font-premium text-2xl text-white mb-4 tracking-wide uppercase">Atención Inmediata</h2>
            <p class="text-white/50 text-sm leading-relaxed font-light">
              Para consultas urgentes, reservas de experiencias de última hora o atención personalizada 1 a 1, conéctese directamente con nuestro Concierge.
            </p>
          </div>

          <div class="space-y-6">
            <a href="https://wa.me/51953435738" target="_blank" class="group flex items-center gap-6 p-6 bg-white/[0.01] border border-white/5 rounded-2xl transition-all duration-300 hover:border-[#C5A059]/40 hover:bg-white/[0.03]">
              <div class="w-12 h-12 rounded-full border border-[#C5A059]/20 flex items-center justify-center text-[#C5A059] group-hover:bg-[#C5A059] group-hover:text-black transition-all">
                <i class="fa-brands fa-whatsapp text-xl"></i>
              </div>
              <div>
                <span class="block text-[10px] uppercase text-[#C5A059] tracking-widest mb-1">Línea Directa</span>
                <span class="text-white text-base font-medium group-hover:text-[#C5A059] transition-colors">WhatsApp Concierge VIP</span>
              </div>
            </a>

            <a href="https://instagram.com/casalg_luxury" target="_blank" class="group flex items-center gap-6 p-6 bg-white/[0.01] border border-white/5 rounded-2xl transition-all duration-300 hover:border-[#C5A059]/40 hover:bg-white/[0.03]">
              <div class="w-12 h-12 rounded-full border border-[#C5A059]/20 flex items-center justify-center text-[#C5A059] group-hover:bg-[#C5A059] group-hover:text-black transition-all">
                <i class="fa-brands fa-instagram text-xl"></i>
              </div>
              <div>
                <span class="block text-[10px] uppercase text-[#C5A059] tracking-widest mb-1">Galeria de Arte</span>
                <span class="text-white text-base font-medium group-hover:text-[#C5A059] transition-colors">@casalg_luxury</span>
              </div>
            </a>
          </div>

          <div class="p-8 border-l-2 border-[#C5A059]/30 bg-white/[0.01] space-y-4">
            <h4 class="font-premium text-xs text-[#C5A059] tracking-widest uppercase">Horario de Atelier</h4>
            <p class="text-white/70 text-sm font-light">Lunes a Sábado: 09:00 AM — 08:00 PM</p>
            <div class="h-[1px] w-full bg-white/5 my-2"></div>
            <h4 class="font-premium text-xs text-[#C5A059] tracking-widest uppercase">Empresas & Eventos</h4>
            <p class="text-white/40 text-xs leading-relaxed font-light">
              Para solicitudes corporativas de gran volumen, dossiers institucionales o cotizaciones de eventos corporativos, sírvase rellenar el formulario adjunto seleccionando la división correspondiente.
            </p>
          </div>
        </div>

        <div class="lg:col-span-7 bg-white/[0.01] border border-white/5 p-8 md:p-12 rounded-[30px] shadow-2xl animate-slide-up [animation-delay:200ms]">
          <form class="space-y-8 font-sans">
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
              <div class="space-y-2">
                <label class="text-[10px] uppercase tracking-widest text-[#C5A059] block">Nombre Completo</label>
                <input type="text" required placeholder="Escriba su nombre" class="w-full bg-white/[0.02] border-b border-white/10 py-3 px-1 text-white placeholder-white/20 focus:outline-none focus:border-[#C5A059] transition-colors text-sm font-light" />
              </div>
              
              <div class="space-y-2">
                <label class="text-[10px] uppercase tracking-widest text-[#C5A059] block">Correo Electrónico</label>
                <input type="email" required placeholder="ejemplo@dominio.com" class="w-full bg-white/[0.02] border-b border-white/10 py-3 px-1 text-white placeholder-white/20 focus:outline-none focus:border-[#C5A059] transition-colors text-sm font-light" />
              </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
              <div class="space-y-2">
                <label class="text-[10px] uppercase tracking-widest text-[#C5A059] block">Teléfono de Contacto</label>
                <input type="tel" placeholder="+51 999 999 999" class="w-full bg-white/[0.02] border-b border-white/10 py-3 px-1 text-white placeholder-white/20 focus:outline-none focus:border-[#C5A059] transition-colors text-sm font-light" />
              </div>

              <div class="space-y-2">
                <label class="text-[10px] uppercase tracking-widest text-[#C5A059] block">Tipo de Consulta</label>
                <div class="relative">
                  <select class="w-full bg-transparent border-b border-white/10 py-3 px-1 text-white/80 focus:outline-none focus:border-[#C5A059] transition-colors text-sm font-light appearance-none cursor-pointer">
                    <option value="personalizado" class="bg-[#0b0707] text-white">Proyecto Personalizado (Atelier)</option>
                    <option value="experiencia" class="bg-[#0b0707] text-white">Reserva de Experiencia VIP</option>
                    <option value="corporate" class="bg-[#0b0707] text-white">Solución Corporativa / B2B</option>
                    <option value="evento" class="bg-[#0b0707] text-white">Eventos & Celebraciones</option>
                  </select>
                  <div class="absolute inset-y-0 right-2 flex items-center pointer-events-none text-white/30">
                    <i class="fa-solid fa-chevron-down text-xs"></i>
                  </div>
                </div>
              </div>
            </div>

            <div class="space-y-2">
              <label class="text-[10px] uppercase tracking-widest text-[#C5A059] block">Detalles de su Solicitud</label>
              <textarea rows="4" placeholder="Describa brevemente cómo podemos ayudarle a forjar su idea..." class="w-full bg-white/[0.02] border border-white/10 rounded-xl p-4 text-white placeholder-white/20 focus:outline-none focus:border-[#C5A059] transition-colors text-sm font-light resize-none"></textarea>
            </div>

            <div class="pt-4">
              <button type="submit" class="w-full py-5 bg-gradient-to-r from-[#C5A059] to-[#8C6D2E] text-black font-sans font-bold uppercase tracking-[0.3em] text-[11px] transition-all hover:opacity-90 active:scale-[0.99] shadow-[0_10px_30px_rgba(197,160,89,0.2)]">
                Enviar Solicitud Privada
              </button>
            </div>

          </form>
        </div>

      </div>

    </div>
  </main>
</Layout>

<style>
  @keyframes slide-up {
    from { transform: translateY(40px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }
  @keyframes fade-in {
    from { opacity: 0; filter: blur(5px); }
    to { opacity: 1; filter: blur(0); }
  }
  .animate-slide-up { animation: slide-up 1s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
  .animate-fade-in { animation: fade-in 1.2s ease-out forwards; }
  .font-premium { font-family: 'Cinzel', serif; }
</style>