---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
---

<Layout title="Diseños Personalizados | Casa L&G">
  <Navbar />
  
  <section class="relative min-h-screen bg-black text-white flex items-center justify-center overflow-hidden pt-20">
    <div class="absolute inset-0 z-0 bg-gradient-to-b from-black via-[#120c0c] to-black"></div>

    <div class="relative z-20 text-center px-6 flex flex-col items-center max-w-3xl mx-auto">
      <p class="font-sans text-brand-gold tracking-[0.4em] text-[10px] md:text-[12px] uppercase mb-6">
        Hecho Exclusivamente Para Ti
      </p>
      
      <h1 class="font-premium text-4xl md:text-7xl text-white mb-8 tracking-wide uppercase leading-tight">
        Piezas de <br/>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-white via-[#C5A059] to-white">
          Autor Único
        </span>
      </h1>
      
      <div class="h-[1px] w-20 bg-[#C5A059]/40 mb-8"></div>
      
      <p class="font-sans text-white/70 text-sm md:text-base leading-relaxed tracking-wide mb-12 max-w-xl">
        Transformamos tus ideas en objetos de herencia. Configura materiales, grabados de monogramas de precisión y detalles a medida guiado directamente por nuestros diseñadores expertos para crear una obra irrepetible.
      </p>

      <div class="flex justify-center">
        <a href="https://wa.me/51953435738" target="_blank" rel="noopener noreferrer" class="group relative inline-flex items-center justify-center px-12 py-4 border border-[#C5A059] overflow-hidden transition-all duration-500 hover:bg-[#C5A059]">
          <span class="relative z-10 font-sans text-[10px] tracking-widest text-[#C5A059] group-hover:text-black uppercase transition-colors">
            Iniciar Diseño Personalizado
          </span>
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .font-premium {
    font-family: 'Cinzel', serif;
  }
</style>