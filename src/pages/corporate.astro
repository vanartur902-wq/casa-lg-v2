---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
---

<Layout title="Soluciones Corporate | Casa L&G">
  <Navbar />
  
  <main class="relative min-h-screen text-white flex flex-col justify-center items-center px-6 pt-32 overflow-hidden" style="background-color: #0b0707;">
    <div class="absolute inset-0 z-0 bg-gradient-to-b from-black/60 to-transparent pointer-events-none"></div>

    <div class="relative z-10 text-center max-w-3xl mx-auto flex flex-col items-center">
      <p class="font-sans text-[#C5A059] tracking-[0.5em] text-[10px] md:text-[11px] uppercase mb-4">
        Regalos de Identidad Corporativa
      </p>
      
      <h1 class="font-premium text-4xl md:text-7xl text-white mb-8 tracking-wide uppercase leading-tight">
        Alianzas de <br/>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-white via-[#C5A059] to-white">
          Alto Nivel
        </span>
      </h1>
      
      <div class="h-[1px] w-16 bg-[#C5A059]/40 mb-8"></div>
      
      <p class="font-sans text-white/70 text-sm md:text-base leading-relaxed tracking-wide mb-12 max-w-xl">
        Elevamos la identidad de tu empresa mediante detalles corporativos sofisticados y personalizados. El regalo ideal para ejecutivos, clientes exclusivos y eventos institucionales que exigen el estándar más alto.
      </p>

      <div class="flex justify-center items-center">
        <a href="https://wa.me/51953435738" target="_blank" rel="noopener noreferrer" class="group relative inline-flex items-center justify-center px-10 py-4 border border-[#C5A059] overflow-hidden transition-all duration-500 hover:bg-[#C5A059]">
          <span class="relative z-10 font-sans text-[10px] tracking-widest text-[#C5A059] group-hover:text-black uppercase transition-colors">
            Contactar Consultor Corporate
          </span>
        </a>
      </div>
    </div>
  </main>
</Layout>

<style>
  .font-premium { font-family: 'Cinzel', serif; }
</style>