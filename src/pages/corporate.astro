---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Corporate | Alianzas de Lujo">
  <main class="relative min-h-screen flex flex-col items-center justify-center px-6 overflow-hidden" style="background: linear-gradient(135deg, #050505 0%, #111111 100%);">
    
    <div class="absolute left-1/2 top-0 w-[1px] h-32 bg-gradient-to-b from-[#C5A059] to-transparent"></div>

    <div class="relative z-10 w-full max-w-4xl text-center">
      <span class="inline-block px-4 py-1 border border-[#C5A059]/30 rounded-full text-[#C5A059] text-[9px] uppercase tracking-[0.4em] mb-10">
        B2B Luxury Solutions
      </span>
      
      <h1 class="font-premium text-5xl md:text-9xl text-white mb-12 tracking-tighter leading-[0.9]">
        IDENTIDAD <br/><span class="text-[#C5A059]">CORPORATIVA</span>
      </h1>
      
      <p class="font-sans text-white/50 text-sm md:text-base leading-loose max-w-xl mx-auto mb-16 italic">
        "El prestigio de una marca se mide por la calidad de sus detalles." Elevamos el branding de su empresa a través de regalos institucionales y piezas de cortesía que reflejan excelencia.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16 text-left">
        <div class="p-6 border-l border-[#C5A059]/20">
            <h3 class="text-white font-premium text-lg mb-2">Exclusividad</h3>
            <p class="text-white/40 text-xs uppercase tracking-tighter">Diseños únicos para CEOs y directivos.</p>
        </div>
        <div class="p-6 border-l border-[#C5A059]/20">
            <h3 class="text-white font-premium text-lg mb-2">Branding</h3>
            <p class="text-white/40 text-xs uppercase tracking-tighter">Grabado de alta precisión de su emblema.</p>
        </div>
        <div class="p-6 border-l border-[#C5A059]/20">
            <h3 class="text-white font-premium text-lg mb-2">Logística</h3>
            <p class="text-white/40 text-xs uppercase tracking-tighter">Entregas nacionales con empaque premium.</p>
        </div>
      </div>

      <a href="https://wa.me/51953435738" target="_blank" class="group px-12 py-4 border border-[#C5A059] text-[#C5A059] font-sans text-[10px] uppercase tracking-[0.3em] transition-all hover:bg-[#C5A059] hover:text-black">
        Solicitar Dossier Corporativo
      </a>
    </div>
  </main>
</Layout>