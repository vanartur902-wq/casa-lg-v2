---
// src/components/Navbar.astro
---
<nav class="fixed w-full z-[100] transition-all duration-500 bg-brand-cream/95 backdrop-blur-md border-b border-brand-gold/10">
  <div class="max-w-7xl mx-auto px-6 py-5 flex justify-between items-center relative">
    
    <div class="flex flex-col z-[110]">
      <span class="text-2xl font-premium tracking-[0.4em] text-brand-dark leading-none">CASA L&G</span>
      <span class="text-[8px] uppercase tracking-[0.5em] text-brand-gold mt-1">Detalles para días especiales y flores</span>
    </div>
    
    <div class="hidden md:flex absolute left-1/2 -translate-x-1/2 space-x-12 font-body text-[10px] uppercase tracking-[0.2em]">
      <a href="/" class="text-brand-dark hover:text-brand-gold transition-colors duration-300">Inicio</a>
      <a href="/catalogo" class="text-brand-dark hover:text-brand-gold transition-colors duration-300">Catálogo</a>
      <a href="/contacto" class="text-brand-dark hover:text-brand-gold transition-colors duration-300">Pedidos</a>
    </div>

    <div class="hidden md:block">
      <a href="https://wa.me/51953435738" class="border border-brand-dark px-6 py-2 text-[9px] uppercase tracking-widest text-brand-dark hover:bg-brand-dark hover:text-white transition-all duration-500">
        WhatsApp VIP
      </a>
    </div>

    <button id="menu-toggle" class="md:hidden flex flex-col justify-center items-end w-10 h-10 gap-[6px] z-[110] focus:outline-none pr-1">
      <span class="line-1 w-8 h-[2px] bg-brand-gold block rounded-full transition-all duration-300"></span>
      <span class="line-2 w-5 h-[2px] bg-brand-gold block rounded-full transition-all duration-300"></span>
      <span class="line-3 w-8 h-[2px] bg-brand-gold block rounded-full transition-all duration-300"></span>
    </button>

    <div id="mobile-menu" class="fixed inset-0 h-screen w-screen bg-brand-dark/90 backdrop-blur-2xl flex flex-col items-center justify-center space-y-10 opacity-0 invisible transition-all duration-500 md:hidden z-[100]">
      <a href="/" class="mobile-link text-2xl font-premium tracking-[0.4em] text-white/90 hover:text-brand-gold">Inicio</a>
      <a href="/catalogo" class="mobile-link text-2xl font-premium tracking-[0.4em] text-white/90 hover:text-brand-gold">Catálogo</a>
      <a href="/contacto" class="mobile-link text-2xl font-premium tracking-[0.4em] text-white/90 hover:text-brand-gold">Pedidos</a>
      
      <div class="w-12 h-[1px] bg-brand-gold/30 my-4"></div>
      
      <a href="https://wa.me/51953435738" class="text-brand-gold text-xs tracking-[0.5em] uppercase font-bold">WhatsApp VIP</a>
    </div>

  </div>
</nav>

<style>
  /* Animaciones de apertura */
  .menu-open #mobile-menu {
    @apply opacity-100 visible;
  }

  /* Animación de las líneas para formar la X al abrir */
  .menu-open .line-1 { transform: translateY(8px) rotate(45deg); }
  .menu-open .line-2 { opacity: 0; transform: translateX(10px); }
  .menu-open .line-3 { transform: translateY(-8px) rotate(-45deg); }

  /* Evita el scroll cuando el menú está abierto */
  :global(body.no-scroll) {
    overflow: hidden;
  }
</style>

<script>
  const initNav = () => {
    const btn = document.getElementById('menu-toggle');
    const nav = document.querySelector('nav');
    const links = document.querySelectorAll('.mobile-link');

    if (btn && nav) {
      // Limpiamos eventos previos para evitar errores en Astro
      btn.onclick = (e) => {
        e.preventDefault();
        nav.classList.toggle('menu-open');
        document.body.classList.toggle('no-scroll');
      };

      links.forEach(link => {
        link.onclick = () => {
          nav.classList.remove('menu-open');
          document.body.classList.remove('no-scroll');
        };
      });
    }
  };

  // Inicialización para carga normal y cambios de página (ViewTransitions)
  initNav();
  document.addEventListener('astro:after-swap', initNav);
</script>