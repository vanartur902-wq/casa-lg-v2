---
// src/components/Navbar.astro
---
<nav class="fixed w-full z-[100] transition-all duration-500 bg-brand-cream/90 backdrop-blur-md border-b border-brand-gold/10">
  <div class="max-w-7xl mx-auto px-6 py-5 flex justify-between items-center relative">
    
    <div class="flex flex-col z-[110]">
      <span class="text-2xl font-premium tracking-[0.4em] text-brand-dark leading-none uppercase">CASA L&G</span>
      <span class="text-[8px] uppercase tracking-[0.5em] text-brand-gold mt-1">Detalles para días especiales y flores</span>
    </div>
    
    <div class="hidden md:flex absolute left-1/2 -translate-x-1/2 space-x-12 font-body text-[10px] uppercase tracking-[0.2em]">
      <a href="/" class="text-brand-dark hover:text-brand-gold transition-colors duration-300">Inicio</a>
      <a href="/catalogo" class="text-brand-dark hover:text-brand-gold transition-colors duration-300">Catálogo</a>
      <a href="/contacto" class="text-brand-dark hover:text-brand-gold transition-colors duration-300">Pedidos</a>
    </div>

    <div class="hidden md:block">
      <a href="https://wa.me/51953435738" class="border border-brand-dark px-6 py-2 text-[9px] uppercase tracking-widest text-brand-dark hover:bg-brand-dark hover:text-white transition-all duration-500">
        WhatsApp VIP
      </a>
    </div>

    <button id="menu-toggle" class="md:hidden flex flex-col justify-center items-end w-10 h-10 space-y-1.5 z-[110] relative" aria-label="Abrir menú">
      <span class="line-1 w-7 h-[1.5px] bg-brand-dark block transition-all duration-300"></span>
      <span class="line-2 w-5 h-[1.5px] bg-brand-dark block transition-all duration-300"></span>
      <span class="line-3 w-7 h-[1.5px] bg-brand-dark block transition-all duration-300"></span>
    </button>

    <div id="mobile-menu" class="fixed inset-0 h-screen w-screen bg-brand-cream flex flex-col items-center justify-center space-y-10 opacity-0 invisible translate-y-[-20px] transition-all duration-500 md:hidden z-[100]">
      <a href="/" class="mobile-link text-3xl font-premium tracking-[0.3em] text-brand-dark">Inicio</a>
      <a href="/catalogo" class="mobile-link text-3xl font-premium tracking-[0.3em] text-brand-dark">Catálogo</a>
      <a href="/contacto" class="mobile-link text-3xl font-premium tracking-[0.3em] text-brand-dark">Pedidos</a>
      
      <div class="h-[1px] w-16 bg-brand-gold/40"></div>
      
      <a href="https://wa.me/51953435738" class="text-brand-gold text-sm tracking-[0.4em] uppercase font-bold">WhatsApp VIP</a>
    </div>

  </div>
</nav>

<style>
  /* Control de apertura con clases de Tailwind y CSS puro */
  .menu-open #mobile-menu {
    @apply opacity-100 visible translate-y-0;
  }

  /* Animación de la X */
  .menu-open .line-1 { transform: translateY(8px) rotate(45deg); }
  .menu-open .line-2 { opacity: 0; transform: translateX(10px); }
  .menu-open .line-3 { transform: translateY(-8px) rotate(-45deg); }

  /* Evita que el usuario haga scroll mientras el menú está abierto */
  :global(body.no-scroll) {
    overflow: hidden;
  }
</style>

<script>
  function initNav() {
    const btn = document.getElementById('menu-toggle');
    const nav = document.querySelector('nav');
    const links = document.querySelectorAll('.mobile-link');

    if (btn && nav) {
      // Usamos un clon para evitar que se dupliquen los eventos con Astro ViewTransitions
      const newBtn = btn.cloneNode(true);
      btn.parentNode.replaceChild(newBtn, btn);

      newBtn.addEventListener('click', () => {
        nav.classList.toggle('menu-open');
        document.body.classList.toggle('no-scroll');
      });

      links.forEach(link => {
        link.addEventListener('click', () => {
          nav.classList.remove('menu-open');
          document.body.classList.remove('no-scroll');
        });
      });
    }
  }

  initNav();
  document.addEventListener('astro:after-swap', initNav);
</script>