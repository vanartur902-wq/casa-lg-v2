---
// src/components/Navbar.astro
---
<nav class="fixed w-full z-[100] bg-brand-cream/95 backdrop-blur-md border-b border-brand-gold/20">
  <div class="max-w-7xl mx-auto px-4 py-4 flex justify-between items-center relative">
    
    <div class="flex flex-col z-[120]">
      <span class="text-xl md:text-2xl font-premium tracking-[0.3em] text-brand-dark leading-none uppercase">CASA L&G</span>
      <span class="text-[7px] uppercase tracking-[0.4em] text-brand-gold mt-1">Detalles para días especiales y flores</span>
    </div>
    
    <div class="hidden md:flex absolute left-1/2 -translate-x-1/2 space-x-10 font-body text-[10px] uppercase tracking-[0.2em]">
      <a href="/" class="text-brand-dark hover:text-brand-gold transition-colors">Inicio</a>
      <a href="/catalogo" class="text-brand-dark hover:text-brand-gold transition-colors">Catálogo</a>
      <a href="/contacto" class="text-brand-dark hover:text-brand-gold transition-colors">Pedidos</a>
    </div>

    <div class="hidden md:block">
      <a href="https://wa.me/51953435738" class="border border-brand-dark px-4 py-2 text-[9px] uppercase tracking-widest text-brand-dark hover:bg-brand-dark hover:text-white transition-all">
        WhatsApp VIP
      </a>
    </div>

    <div id="menu-toggle" class="md:hidden flex flex-col justify-center items-end w-12 h-12 gap-1.5 z-[130] cursor-pointer touch-none">
      <div class="line-1 w-8 h-[2px] bg-brand-dark transition-all duration-300"></div>
      <div class="line-2 w-5 h-[2px] bg-brand-dark transition-all duration-300"></div>
      <div class="line-3 w-8 h-[2px] bg-brand-dark transition-all duration-300"></div>
    </div>

    <div id="mobile-menu" class="fixed inset-0 w-full h-screen bg-brand-cream flex flex-col items-center justify-center space-y-10 transition-all duration-500 translate-x-full z-[110]">
      <a href="/" class="mobile-link text-2xl font-premium tracking-[0.2em] text-brand-dark">INICIO</a>
      <a href="/catalogo" class="mobile-link text-2xl font-premium tracking-[0.2em] text-brand-dark">CATÁLOGO</a>
      <a href="/contacto" class="mobile-link text-2xl font-premium tracking-[0.2em] text-brand-dark">PEDIDOS</a>
      <div class="w-10 h-[1px] bg-brand-gold/50"></div>
      <a href="https://wa.me/51953435738" class="text-brand-gold text-xs tracking-[0.3em] font-bold">WHATSAPP VIP</a>
    </div>

  </div>
</nav>

<style>
  /* Cuando el menú está abierto */
  .menu-open #mobile-menu {
    transform: translateX(0);
  }

  .menu-open .line-1 { transform: translateY(8px) rotate(45deg); }
  .menu-open .line-2 { opacity: 0; }
  .menu-open .line-3 { transform: translateY(-8px) rotate(-45deg); }

  :global(body.no-scroll) { overflow: hidden; }
</style>

<script>
  function setupNav() {
    const btn = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');
    const links = document.querySelectorAll('.mobile-link');
    const nav = document.querySelector('nav');

    if (btn && menu) {
      btn.onclick = (e) => {
        e.preventDefault();
        nav.classList.toggle('menu-open');
        document.body.classList.toggle('no-scroll');
      };

      links.forEach(link => {
        link.onclick = () => {
          nav.classList.remove('menu-open');
          document.body.classList.remove('no-scroll');
        };
      });
    }
  }

  setupNav();
  document.addEventListener('astro:after-swap', setupNav);
</script>