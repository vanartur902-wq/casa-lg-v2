---
const currentYear = new Date().getFullYear();
---
<footer class="bg-[#080808] border-t border-white/5 py-12 px-8 mt-20">
  <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-8">
    <div class="text-center md:text-left">
      <h3 class="font-['Cinzel'] text-xl tracking-[0.3em] text-white">CASA L&G</h3>
      <p class="text-[9px] text-[#C5A059] tracking-widest uppercase mt-2">Exclusividad en cada detalle</p>
    </div>
    
    <div class="flex space-x-8">
      <a href="#" class="text-white/40 hover:text-[#C5A059] transition-colors text-[10px] tracking-widest uppercase">Instagram</a>
      <a href="#" class="text-white/40 hover:text-[#C5A059] transition-colors text-[10px] tracking-widest uppercase">WhatsApp VIP</a>
    </div>

    <p class="text-white/20 text-[8px] tracking-widest uppercase">
      &copy; {currentYear} Casa L&G. Todos los derechos reservados.
    </p>
